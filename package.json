{
  "name": "gossamer-utils",
  "displayName": "Gossamer Utils",
  "description": "Personal front-end utils",
  "version": "0.0.3",
  "author": {
    "name": "Talovsky",
    "email": "nika.talovsky@gmail.com",
    "url": "https://www.github.com/talovsky"
  },
  "icon": "assets/icon.png",
  "repository": {
    "url": "https://github.com/talovsky/gossamer-utils",
    "type": "git"
  },
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:html",
    "onLanguage:svelte",
    "onLanguage:astro",
    "onLanguage:vue"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gossamer-utils.jumpToMatchingBracketOrTag",
        "title": "Jump to Matching Bracket or Tag"
      },
      {
        "command": "gossamer-utils.jumpToMatchingTag",
        "title": "Match Tag",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.removeTagPreserveChildren",
        "title": "Remove Tag",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.balanceTagInward",
        "title": "Balance Inward",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.balanceTagOutward",
        "title": "Balance Outward",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.renameSymbol",
        "title": "Rename Symbol",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.goToDefinition",
        "title": "Go to Definition",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.convertFunctionToArrow",
        "title": "Convert Function Declaration to Arrow Function",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.convertArrowToFunction",
        "title": "Convert Arrow Function to Function Declaration",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.wrapSelectionWithTag",
        "title": "Wrap Selection with Tag",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.wrapSelectionInUseMemo",
        "title": "Wrap Selection in useMemo",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.wrapSelectionInUseCallback",
        "title": "Wrap Selection in useCallback",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.wrapSelectionInFragment",
        "title": "Wrap Selection in Fragment",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.toggleTabOut",
        "title": "Toggle TabOut",
        "category": "Gossamer Utils"
        },
        {
        "command": "gossamer-utils.hungryDelete",
        "title": "Hungry Delete",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.showOpenedEditors",
        "title": "Show Opened Editors",
        "category": "Gossamer Utils"
      },
      {
        "command": "gossamer-utils.showQuickOpenWithPath",
        "title": "Show Quick Open with Current Path",
        "category": "Gossamer Utils"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Gossamer Utils",
      "properties": {
        "gossamer-utils.framework": {
          "type": "string",
          "enum": [
            "react",
            "solid"
          ],
          "default": "react",
          "description": "Framework mode used to filter framework-specific Quick Fix actions."
        },
        "gossamer-utils.tabout.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable TabOut navigation with the Tab key."
        },
        "gossamer-utils.tabOut.enableReverseShiftTab": {
          "type": "boolean",
          "default": true,
          "description": "Enable reverse TabOut navigation with Shift+Tab."
        },
        "gossamer-utils.tabOut.characters": {
          "type": "array",
          "description": "Opening and closing character pairs to tab out from.",
          "default": [
            {
              "open": "[",
              "close": "]"
            },
            {
              "open": "{",
              "close": "}"
            },
            {
              "open": "(",
              "close": ")"
            },
            {
              "open": "'",
              "close": "'"
            },
            {
              "open": "\"",
              "close": "\""
            },
            {
              "open": ":",
              "close": ":"
            },
            {
              "open": "=",
              "close": "="
            },
            {
              "open": ">",
              "close": ">"
            },
            {
              "open": "<",
              "close": "<"
            },
            {
              "open": ".",
              "close": "."
            },
            {
              "open": "`",
              "close": "`"
            },
            {
              "open": ";",
              "close": ";"
            }
          ],
          "items": {
            "type": "object",
            "required": [
              "open",
              "close"
            ],
            "properties": {
              "open": {
                "type": "string",
                "description": "Opening character."
              },
              "close": {
                "type": "string",
                "description": "Closing character."
              }
            }
          }
        },
        "gossamer-utils.hungryDelete.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Backspace to delete contiguous spaces and tabs before the cursor."
        }
      }
    },
    "keybindings": [
      {
        "command": "gossamer-utils.jumpToMatchingBracketOrTag",
        "key": "ctrl+shift+\\",
        "mac": "cmd+shift+\\",
        "when": "editorTextFocus"
      },
      {
        "command": "gossamer-utils.tabout",
        "key": "tab",
        "mac": "tab",
        "when": "config.gossamer-utils.tabout.enabled && editorTextFocus && !editorHasSelection && !suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible"
      },
      {
        "command": "gossamer-utils.taboutReverse",
        "key": "shift+tab",
        "mac": "shift+tab",
        "when": "config.gossamer-utils.tabout.enabled && config.gossamer-utils.tabout.enableReverseShiftTab && editorTextFocus && !editorHasSelection && !suggestWidgetVisible && !inlineSuggestionVisible && !inlineEditIsVisible"
      },
      {
        "command": "gossamer-utils.hungryDelete",
        "key": "backspace",
        "mac": "backspace",
        "when": "config.gossamer-utils.hungryDelete.enabled && editorTextFocus && !editorReadonly"
      },
      {
        "command": "gossamer-utils.showOpenedEditors",
        "key": "alt+ctrl+p",
        "mac": "alt+cmd+p"
      },
      {
        "command": "gossamer-utils.showQuickOpenWithPath",
        "key": "ctrl+ctrl+p",
        "mac": "ctrl+cmd+p"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsix": "pnpm run package && pnpm dlx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
